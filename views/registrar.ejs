<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/jpeg" href="/logo.jpg"/>
<title>VisionGuard – Acesso</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',Arial,sans-serif;background:#080a0f;min-height:100vh;display:flex;align-items:center;justify-content:center;color:#eef0f5;padding:20px}
.card{width:100%;max-width:380px;background:#0f1219;border:1px solid rgba(255,255,255,0.06);border-radius:20px;padding:32px;box-shadow:0 24px 64px rgba(0,0,0,0.5)}
.brand{display:flex;flex-direction:column;align-items:center;gap:10px;margin-bottom:28px}
.brand-logo{width:64px;height:64px;border-radius:14px;overflow:hidden;border:1px solid rgba(78,127,255,0.3);box-shadow:0 0 20px rgba(78,127,255,0.15)}
.brand-logo img{width:100%;height:100%;object-fit:cover;display:block}
.brand-nome{font-family:Rajdhani,sans-serif;font-size:22px;font-weight:700;color:#eef0f5}
.brand-sub{font-size:12px;color:#454955;text-transform:uppercase;letter-spacing:.06em}
.form-group{margin-bottom:16px}
.form-group label{display:block;margin-bottom:6px;color:#8b909e;font-size:12px;text-transform:uppercase;letter-spacing:.05em}
.form-group input{width:100%;padding:12px 14px;border:1px solid rgba(255,255,255,0.06);border-radius:8px;background:#131720;color:#eef0f5;font-family:Inter,sans-serif;font-size:14px;outline:none;transition:border-color .2s;text-transform:uppercase;letter-spacing:.1em;text-align:center}
.form-group input:focus{border-color:#4e7fff}
.form-group input::placeholder{text-transform:none;letter-spacing:0;text-align:left}
.btn{width:100%;padding:12px;border:none;border-radius:8px;background:#4e7fff;color:#fff;font-family:Inter,sans-serif;font-size:14px;font-weight:600;cursor:pointer;margin-top:8px;transition:opacity .15s}
.btn:hover{opacity:.88}
.erro{background:rgba(224,92,92,0.1);border:1px solid rgba(224,92,92,0.3);color:#e05c5c;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:16px;text-align:center}
.info{margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.04);text-align:center;font-size:12px;color:#454955}
</style>
</head>
<body>
<div class="card">
  <div class="brand">
    <div class="brand-logo"><img src="/logo.jpg" alt="VisionGuard"></div>
    <div class="brand-nome">VisionGuard</div>
    <div class="brand-sub">Registro de ocorrência</div>
  </div>

  <% if (erro) { %>
    <div class="erro"><%= erro %></div>
  <% } %>

  <form method="POST" action="/registrar/verificar">
    <div class="form-group">
      <label>Código da loja</label>
      <input type="text" name="codigo" placeholder="Ex: KCH-028" required autocomplete="off" maxlength="20">
    </div>
    <button type="submit" class="btn">Continuar</button>
  </form>

  <div class="info">Digite o código fornecido pelo administrador</div>
</div>
</body>
</html>
