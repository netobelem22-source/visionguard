<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/jpeg" href="/logo.jpg"/>
<title>Status de Ocorrências – VisionGuard</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',Arial,sans-serif;background:#080a0f;min-height:100vh;color:#eef0f5;padding:20px}
.container{max-width:700px;margin:0 auto}
.card{background:#0f1219;border:1px solid rgba(255,255,255,0.06);border-radius:20px;padding:28px;box-shadow:0 24px 64px rgba(0,0,0,0.5);margin-bottom:20px}
.brand{display:flex;flex-direction:column;align-items:center;gap:10px;margin-bottom:24px}
.brand-logo{width:56px;height:56px;border-radius:12px;overflow:hidden;border:1px solid rgba(78,127,255,0.3)}
.brand-logo img{width:100%;height:100%;object-fit:cover;display:block}
.brand-nome{font-family:Rajdhani,sans-serif;font-size:20px;font-weight:700;color:#eef0f5}
.brand-sub{font-size:12px;color:#454955;text-transform:uppercase;letter-spacing:.06em}
.form-group{margin-bottom:14px}
.form-group label{display:block;margin-bottom:5px;color:#8b909e;font-size:12px;text-transform:uppercase;letter-spacing:.05em}
.form-group input{width:100%;padding:11px 14px;border:1px solid rgba(255,255,255,0.06);border-radius:8px;background:#131720;color:#eef0f5;font-family:Inter,sans-serif;font-size:14px;outline:none;text-transform:uppercase;letter-spacing:.1em;text-align:center}
.form-group input:focus{border-color:#4e7fff}
.btn{width:100%;padding:12px;border:none;border-radius:8px;background:#4e7fff;color:#fff;font-family:Inter,sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:opacity .15s}
.btn:hover{opacity:.88}
.erro{background:rgba(224,92,92,0.1);border:1px solid rgba(224,92,92,0.3);color:#e05c5c;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:14px;text-align:center}
.loja-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:10px}
.loja-nome{font-family:Rajdhani,sans-serif;font-size:22px;font-weight:700;color:#eef0f5}
.loja-codigo{background:rgba(78,127,255,0.1);border:1px solid rgba(78,127,255,0.2);color:#4e7fff;border-radius:20px;padding:4px 14px;font-size:12px;font-weight:600;font-family:monospace}
.total-info{font-size:13px;color:#454955;margin-bottom:16px}
.registro-item{display:flex;gap:14px;padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.04);align-items:flex-start}
.registro-item:last-child{border-bottom:none}
.registro-img{width:56px;height:56px;border-radius:8px;object-fit:cover;flex-shrink:0}
.registro-info{flex:1}
.registro-nome{font-size:13px;color:#eef0f5;font-weight:500;margin-bottom:3px}
.registro-data{font-size:11px;color:#454955;margin-bottom:6px}
.registro-obs{font-size:11px;color:#8b909e;margin-top:4px}
.badge{display:inline-block;padding:3px 10px;border-radius:10px;font-size:11px;font-weight:600}
.badge-pendente{background:rgba(224,138,60,0.15);color:#e08a3c}
.badge-aprovado{background:rgba(60,184,168,0.15);color:#3cb8a8}
.badge-recusado{background:rgba(224,92,92,0.15);color:#e05c5c}
.empty{text-align:center;padding:40px 0;color:#454955;font-size:13px}
.trocar-link{text-align:center;margin-top:16px;font-size:12px}
.trocar-link a{color:#454955;text-decoration:none}
.trocar-link a:hover{color:#8b909e}
.nova-ocorrencia{display:block;text-align:center;background:rgba(78,127,255,0.1);border:1px solid rgba(78,127,255,0.2);color:#4e7fff;border-radius:8px;padding:10px;font-size:13px;font-weight:600;text-decoration:none;margin-top:10px}

/* Paginação */
.paginacao{display:flex;justify-content:center;gap:6px;margin-top:20px;flex-wrap:wrap}
.paginacao form{display:inline}
.pag-btn{background:#131720;border:1px solid rgba(255,255,255,0.06);color:#8b909e;border-radius:8px;padding:7px 12px;cursor:pointer;font-family:Inter,sans-serif;font-size:13px;transition:all .15s}
.pag-btn:hover{border-color:#4e7fff;color:#4e7fff}
.pag-btn.ativo{background:#4e7fff;border-color:#4e7fff;color:#fff}
</style>
</head>
<body>
<div class="container">

<% if (!loja) { %>
  <div class="card">
    <div class="brand">
      <div class="brand-logo"><img src="/logo.jpg" alt="VisionGuard"></div>
      <div class="brand-nome">VisionGuard</div>
      <div class="brand-sub">Acompanhamento de ocorrências</div>
    </div>

    <% if (erro) { %>
      <div class="erro"><%= erro %></div>
    <% } %>

    <form method="POST" action="/registrar/status">
      <div class="form-group">
        <label>Código da loja</label>
        <input type="text" name="codigo" placeholder="Ex: KCH-028" required autocomplete="off" maxlength="20">
      </div>
      <button type="submit" class="btn">Ver ocorrências</button>
    </form>

    <div class="trocar-link" style="margin-top:16px"><a href="/registrar">← Enviar nova ocorrência</a></div>
  </div>

<% } else { %>
  <div class="card">
    <div class="loja-header">
      <div class="loja-nome"><%= loja.nome %></div>
      <span class="loja-codigo"><%= loja.codigo %></span>
    </div>

    <% if (registros.length === 0) { %>
      <div class="empty">Nenhuma ocorrência registrada ainda.</div>
    <% } else { %>
      <p class="total-info">Página <%= pagina %> de <%= totalPaginas %></p>
      <% registros.forEach(r => { %>
        <div class="registro-item">
          <img src="<%= r.imagem %>" alt="" class="registro-img">
          <div class="registro-info">
            <div class="registro-nome"><%= r.nome %></div>
            <div class="registro-data"><%= new Date(r.data).toLocaleString('pt-BR') %></div>
            <span class="badge badge-<%= r.status || 'aprovado' %>">
              <%= r.status === 'pendente' ? 'Aguardando avaliação' : r.status === 'recusado' ? 'Recusado' : 'Aprovado' %>
            </span>
            <% if (r.observacao) { %>
              <div class="registro-obs">Obs: <%= r.observacao %></div>
            <% } %>
          </div>
        </div>
      <% }) %>

      <!-- Paginação -->
      <% if (totalPaginas > 1) { %>
      <div class="paginacao">
        <% if (pagina > 1) { %>
          <form method="POST" action="/registrar/status">
            <input type="hidden" name="codigo" value="<%= codigo %>">
            <input type="hidden" name="pagina" value="<%= pagina - 1 %>">
            <button type="submit" class="pag-btn">‹</button>
          </form>
        <% } %>
        <% for(let i = 1; i <= totalPaginas; i++) { %>
          <form method="POST" action="/registrar/status">
            <input type="hidden" name="codigo" value="<%= codigo %>">
            <input type="hidden" name="pagina" value="<%= i %>">
            <button type="submit" class="pag-btn <%= i === pagina ? 'ativo' : '' %>"><%= i %></button>
          </form>
        <% } %>
        <% if (pagina < totalPaginas) { %>
          <form method="POST" action="/registrar/status">
            <input type="hidden" name="codigo" value="<%= codigo %>">
            <input type="hidden" name="pagina" value="<%= pagina + 1 %>">
            <button type="submit" class="pag-btn">›</button>
          </form>
        <% } %>
      </div>
      <% } %>
    <% } %>

    <a href="/registrar" class="nova-ocorrencia">+ Registrar nova ocorrência</a>
    <div class="trocar-link"><a href="/registrar/status">← Consultar outra loja</a></div>
  </div>
<% } %>

</div>
</body>
</html>
