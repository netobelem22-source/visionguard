<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/jpeg" href="/logo.jpg"/>
<title>Registrar Ocorrência – VisionGuard</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',Arial,sans-serif;background:#080a0f;min-height:100vh;display:flex;align-items:center;justify-content:center;color:#eef0f5;padding:20px}
.card{width:100%;max-width:420px;background:#0f1219;border:1px solid rgba(255,255,255,0.06);border-radius:20px;padding:32px;box-shadow:0 24px 64px rgba(0,0,0,0.5)}
.brand{display:flex;flex-direction:column;align-items:center;gap:10px;margin-bottom:24px}
.brand-logo{width:56px;height:56px;border-radius:12px;overflow:hidden;border:1px solid rgba(78,127,255,0.3)}
.brand-logo img{width:100%;height:100%;object-fit:cover;display:block}
.brand-nome{font-family:Rajdhani,sans-serif;font-size:20px;font-weight:700;color:#eef0f5}
.loja-badge{background:rgba(78,127,255,0.1);border:1px solid rgba(78,127,255,0.2);color:#4e7fff;border-radius:20px;padding:4px 14px;font-size:12px;font-weight:600}
.form-group{margin-bottom:14px}
.form-group label{display:block;margin-bottom:5px;color:#8b909e;font-size:12px;text-transform:uppercase;letter-spacing:.05em}
.form-group input,.form-group textarea{width:100%;padding:10px 14px;border:1px solid rgba(255,255,255,0.06);border-radius:8px;background:#131720;color:#eef0f5;font-family:Inter,sans-serif;font-size:13px;outline:none;transition:border-color .2s}
.form-group input:focus,.form-group textarea:focus{border-color:#4e7fff}
.form-group input[type=datetime-local]{color-scheme:dark}
.upload-area{border:1px dashed rgba(255,255,255,0.12);border-radius:10px;padding:24px;text-align:center;cursor:pointer;transition:border-color .2s;position:relative}
.upload-area:hover{border-color:#4e7fff;background:rgba(78,127,255,0.03)}
.upload-area input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer}
.upload-area p{font-size:13px;color:#8b909e;margin-bottom:3px}
.upload-area small{font-size:11px;color:#454955}
.preview{display:none;margin-top:10px}
.preview img{width:100%;border-radius:8px;max-height:180px;object-fit:cover}
.btn{width:100%;padding:12px;border:none;border-radius:8px;background:#4e7fff;color:#fff;font-family:Inter,sans-serif;font-size:14px;font-weight:600;cursor:pointer;margin-top:8px;transition:opacity .15s}
.btn:hover{opacity:.88}
.erro{background:rgba(224,92,92,0.1);border:1px solid rgba(224,92,92,0.3);color:#e05c5c;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:14px;text-align:center}
.sucesso{background:rgba(60,184,168,0.1);border:1px solid rgba(60,184,168,0.3);color:#3cb8a8;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:14px;text-align:center}
.loading{display:none;text-align:center;padding:20px 0}
.loading p{font-size:13px;color:#8b909e;margin-top:10px}
.spinner{width:36px;height:36px;border:3px solid rgba(78,127,255,0.2);border-top-color:#4e7fff;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto}
@keyframes spin{to{transform:rotate(360deg)}}
.nova-btn{display:block;text-align:center;background:rgba(78,127,255,0.1);border:1px solid rgba(78,127,255,0.2);color:#4e7fff;border-radius:8px;padding:10px;font-size:13px;font-weight:600;text-decoration:none;margin-top:10px}
.sair-link{text-align:center;margin-top:16px;font-size:12px;color:#454955}
.sair-link a{color:#454955;text-decoration:none}
.sair-link a:hover{color:#8b909e}
</style>
</head>
<body>
<div class="card">
  <div class="brand">
    <div class="brand-logo"><img src="/logo.jpg" alt="VisionGuard"></div>
    <div class="brand-nome">VisionGuard</div>
    <span class="loja-badge"><%= loja.nome %></span>
  </div>

  <% if (erro) { %>
    <div class="erro"><%= erro %></div>
  <% } %>
  <% if (sucesso) { %>
    <div class="sucesso"><%= sucesso %></div>
  <% } %>

  <% if (!sucesso) { %>
  <form method="POST" action="/registrar/enviar" enctype="multipart/form-data" id="form-registro">

    <div class="form-group">
      <label>Caminho da pasta</label>
      <input type="text" name="caminho" placeholder="Ex: C:\Cameras\Loja28\" required autocomplete="off">
    </div>

    <div class="form-group">
      <label>Descrição</label>
      <input type="text" name="descricao" placeholder="Ex: Furto - Setor Bebidas" required autocomplete="off">
    </div>

    <div class="form-group">
      <label>Data e hora da ocorrência</label>
      <input type="datetime-local" name="data_ocorrencia" id="data_ocorrencia" required>
    </div>

    <div class="form-group">
      <label>Foto da pessoa</label>
      <div class="upload-area">
        <input type="file" name="foto" accept="image/jpeg,image/png" id="input-foto" required>
        <p>Toque para selecionar foto</p>
        <small>JPG ou PNG · máximo 10MB</small>
      </div>
      <div class="preview" id="preview">
        <img id="preview-img" src="" alt="Preview">
      </div>
    </div>

    <button type="submit" class="btn" id="btn-enviar">Enviar para avaliação</button>
  </form>

  <div class="loading" id="loading">
    <div class="spinner"></div>
    <p>Processando imagem...<br>Aguarde até 30 segundos.</p>
  </div>
  <% } %>

  <% if (sucesso) { %>
    <a href="/registrar/enviar" class="nova-btn">Registrar nova ocorrência</a>
  <% } %>

  <div class="sair-link"><a href="/registrar">Trocar loja</a></div>
</div>

<script src="/registrar.js"></script>
</body>
</html>
