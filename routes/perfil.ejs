<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/jpeg" href="/logo.jpg"/>
<title>Perfil – VisionGuard</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css"/>
<style>
.perfil-wrap { padding: 0 28px 40px; }
.perfil-header {
  background: #131720;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 24px;
  margin-bottom: 28px;
  display: flex;
  gap: 24px;
  align-items: flex-start;
}
.perfil-info h2 { font-family: Rajdhani,sans-serif; font-size: 24px; font-weight: 700; color: #eef0f5; margin-bottom: 8px; }
.perfil-info p { font-size: 13px; color: #8b909e; margin-bottom: 6px; }
.badge-grupo { display:inline-block; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; margin-bottom: 10px; }
.badge-quadrilha { background: rgba(224,92,92,0.15); color: #e05c5c; }
.badge-furto { background: rgba(224,138,60,0.15); color: #e08a3c; }
.badge-assedio { background: rgba(155,114,207,0.15); color: #9b72cf; }
.badge-reincidente { background: rgba(78,127,255,0.15); color: #4e7fff; }
.badge-suspeito { background: rgba(139,144,158,0.15); color: #8b909e; }
.ocorrencias-titulo { font-family: Rajdhani,sans-serif; font-size: 18px; font-weight: 700; color: #eef0f5; margin-bottom: 16px; }
.ocorrencias-count { font-size: 13px; color: #454955; margin-left: 8px; }
</style>
</head>
<body>

<aside class="sidebar">
  <div class="brand">
    <div class="brand-logo-wrap">
      <img src="data:image/jpeg;base64," alt="Grupo Koch" class="brand-logo">
    </div>
    <span class="brand-label">VisionGuard</span>
  </div>
  <nav class="menu">
    <a href="/" class="menu-btn">⊘ &nbsp;Blacklist</a>
    <a href="/relatorios" class="menu-btn">▤ &nbsp;Relatórios</a>
    <% if (typeof usuario !== 'undefined' && usuario && usuario.nivel === 'admin') { %>
      <a href="/admin/usuarios" class="menu-btn">👥 &nbsp;Usuários</a>
    <% } %>
    <a href="/configuracoes" class="menu-btn">⚙ &nbsp;Configurações</a>
  </nav>
  <a href="/logout" class="logout">↪ &nbsp;Sair</a>
</aside>

<div class="main-content">

  <div class="topo">
    <div class="titulo">Perfil da Pessoa</div>
    <div class="stats-row">
      <div class="stat-chip">
        <div class="val"><%= registros.length %></div>
        <div class="lbl">Ocorrências</div>
      </div>
    </div>
  </div>

  <div class="perfil-wrap">

    <div class="perfil-header">
      <div class="perfil-info">
        <h2><%= pessoa.nome %></h2>
        <% if (pessoa.grupo) { %>
          <span class="badge-grupo badge-<%= pessoa.grupo %>"><%= pessoa.grupo.toUpperCase() %></span>
        <% } %>
        <% if (pessoa.nome_grupo) { %>
          <p>👥 Grupo: <strong style="color:#eef0f5"><%= pessoa.nome_grupo %></strong></p>
        <% } %>
        <% if (pessoa.observacao) { %>
          <p>📝 <%= pessoa.observacao %></p>
        <% } %>
        <p style="margin-top:8px;color:#454955;font-size:12px">Cadastrado em: <%= new Date(pessoa.criado_em).toLocaleDateString('pt-BR') %></p>
      </div>
    </div>

    <div class="ocorrencias-titulo">
      Ocorrências <span class="ocorrencias-count">(<%= registros.length %>)</span>
    </div>

    <div class="grid">
    <% registros.forEach((r, idx) => { %>
      <div class="card">
        <img src="<%= r.imagem %>" alt="">
        <div class="card-content">
          <h2><%= r.nome %></h2>
          <div class="data"><%= new Date(r.data).toLocaleString('pt-BR') %></div>
          <% if (r.grupo) { %>
            <span class="badge-grupo badge-<%= r.grupo %>" style="font-size:10px;margin-bottom:8px;display:inline-block"><%= r.grupo %></span>
          <% } %>
          <div class="botoes">
            <a class="download" href="/download?arquivo=<%= r.imagem %>" download>⬇ Download</a>
          </div>
        </div>
      </div>
    <% }) %>
    </div>

  </div>
</div>
</body>
</html>