# PostgreSQL (usuarios/login)
DB_USER=vgadmin
DB_PASS=troque-esta-senha
DB_NAME=visionguard_users

# Sessao Express - gere uma string aleatoria longa (ex: openssl rand -hex 32)
SESSION_SECRET=troque-este-valor

# Envio de email (Gmail) - use uma App Password, nunca a senha normal da conta
GMAIL_USER=seu-email@gmail.com
GMAIL_PASS=sua-app-password

# Concorrencia de processamento (opcional)
FILA_CONCURRENCIA=2
FACE_POOL_SIZE=2
